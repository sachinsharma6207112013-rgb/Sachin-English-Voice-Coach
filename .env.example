GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Optional but recommended for persistent signup/login and chat history.
# Without DATABASE_URL, auth falls back to a local dev file (.auth-local-users.json).
# Example providers: Neon, Supabase, Railway, Vercel Postgres.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional:
# Set to false if your database does not require SSL.
DATABASE_SSL=true
